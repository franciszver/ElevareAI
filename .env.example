# ============================================================================
# ElevareAI - Environment Variables
# ============================================================================
# Copy this file to .env. These values work out of the box for local
# development with the docker-compose Postgres (docker compose up -d postgres).
# Only OPENROUTER_API_KEY needs a real value, and only for live AI features
# (tests never need it — AI is mocked).
#
# DO NOT commit .env to version control.
#
# Every variable must have a matching field in src/config/settings.py
# (Settings uses extra="forbid" — unknown variables crash the app at startup).
# All other settings (rate limits, thresholds, feature flags) have sensible
# defaults in settings.py; set them here only to override.
# ============================================================================

# Database (matches docker-compose defaults)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=elevareai
DB_USER=postgres
DB_PASSWORD=postgres

# AI provider (OpenRouter)
# Free-tier model with no rate limits. Base URL defaults to https://openrouter.ai/api/v1
# (set OPENROUTER_BASE_URL environment variable to override).
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key-here
OPENROUTER_MODEL=openai/gpt-oss-20b:free

# Application
ENVIRONMENT=development
LOG_LEVEL=INFO

# Auth (JWT signing secret for locally-issued access tokens)
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=replace-with-a-generated-secret

# Demo accounts (password for demo@elevare.ai / tutor@elevare.ai / parent@elevare.ai,
# seeded by scripts/seed_demo_data.py). Set a real value BEFORE the first seed of a fresh
# database — the seed uses this as the actual demo login password (existing users are never
# overwritten on re-runs). Never commit .env to version control.
DEMO_PASSWORD=set-a-demo-password-here

# CORS (comma-separated list of allowed origins). Defaults to * which is fine
# for local dev; set explicit origins in production.
# ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend.onrender.com
