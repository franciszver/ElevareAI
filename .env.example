# ============================================================================
# ElevareAI - Environment Variables Example
# ============================================================================
# Copy this file to .env — the values below work out of the box for local
# development with the docker-compose Postgres (docker compose up -d postgres).
# Only OPENAI_API_KEY needs a real value, and only for live AI features
# (tests never need it — AI is mocked).
#
# DO NOT commit .env to version control.
#
# Note: every variable here must have a matching field in
# src/config/settings.py (Settings uses extra="forbid" — unknown variables
# crash the app at startup).
# ============================================================================

# ============================================================================
# Database (matches docker-compose defaults)
# ============================================================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=elevareai
DB_USER=postgres
DB_PASSWORD=postgres
# DB_POOL_SIZE=5
# DB_MAX_OVERFLOW=10

# ============================================================================
# AI / OpenAI-compatible provider
# ============================================================================
# Migration in progress: moving to OpenRouter (https://openrouter.ai).
# Once Phase 1 lands, use an OpenRouter key (sk-or-v1-...) and the settings
# below; until then this is an OpenAI key.
OPENAI_API_KEY=your-api-key-here
OPENAI_MODEL=gpt-4
# Coming in Phase 1 (do not uncomment before the openai_base_url setting exists):
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_MODEL=openai/gpt-oss-20b:free
# OPENAI_TEMPERATURE=0.7
# OPENAI_MAX_TOKENS=2000

# ============================================================================
# Application
# ============================================================================
ENVIRONMENT=development
LOG_LEVEL=INFO
# API_VERSION=v1
# API_BASE_URL=http://localhost:8000
# Note: the server port is set via `uvicorn --port`, not an env var.

# ============================================================================
# AWS (LEGACY — being removed in Phases 2-3; no AWS access required for
# local development. Leave commented out.)
# ============================================================================
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# COGNITO_USER_POOL_ID=
# COGNITO_CLIENT_ID=
# COGNITO_REGION=us-east-1
# SES_FROM_EMAIL=noreply@example.com
# SES_REGION=us-east-1
# S3_BUCKET_NAME=
# S3_REGION=us-east-1

# ============================================================================
# Optional tuning (defaults in src/config/settings.py are sensible;
# uncomment only to override)
# ============================================================================
# AI_SERVICE_API_KEY=
# ENABLE_AI_PRACTICE_GENERATION=true
# ENABLE_NUDGES=true
# ENABLE_ANALYTICS=true
# RATE_LIMIT_PER_MINUTE=100
# RATE_LIMIT_PER_HOUR=1000
# DEFAULT_NUDGE_FREQUENCY_CAP=1
# NUDGE_INACTIVITY_THRESHOLD_DAYS=7
# NUDGE_MIN_SESSIONS_THRESHOLD=3
# CONFIDENCE_HIGH_THRESHOLD=0.75
# CONFIDENCE_MEDIUM_THRESHOLD=0.50
# ELO_K_FACTOR=32
# ELO_DEFAULT_RATING=1000
# ELO_MIN_RATING=400
# ELO_MAX_RATING=2000
# RAILS_APP_URL=
# WEBHOOK_SECRET=
