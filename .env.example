# ============================================================================
# ElevareAI - Environment Variables
# ============================================================================
# Copy this file to .env. These values work out of the box for local
# development with the docker-compose Postgres (docker compose up -d postgres).
# Only OPENAI_API_KEY needs a real value, and only for live AI features
# (tests never need it — AI is mocked).
#
# DO NOT commit .env to version control.
#
# Every variable must have a matching field in src/config/settings.py
# (Settings uses extra="forbid" — unknown variables crash the app at startup).
# All other settings (rate limits, thresholds, feature flags) have sensible
# defaults in settings.py; set them here only to override.
# ============================================================================

# Database (matches docker-compose defaults)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=elevareai
DB_USER=postgres
DB_PASSWORD=postgres

# AI provider (OpenAI-compatible)
# Migrating to OpenRouter in Phase 1: key becomes sk-or-v1-..., model becomes
# openai/gpt-oss-20b:free, and OPENAI_BASE_URL=https://openrouter.ai/api/v1
# gets added once the setting exists.
OPENAI_API_KEY=your-api-key-here
OPENAI_MODEL=gpt-4

# Application
ENVIRONMENT=development
LOG_LEVEL=INFO
